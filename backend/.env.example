ENV=dev
DATABASE_URL=sqlite:///./betweenus.db
AI_PROVIDER_MODE=auto
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
ASR_PROVIDER=openai_compatible
ASR_API_KEY=
ASR_BASE_URL=https://api.openai.com/v1
ASR_MODEL=whisper-1
ASR_LANGUAGE=zh
ASR_VOLC_APP_ID=
ASR_VOLC_ACCESS_TOKEN=
ASR_VOLC_RESOURCE_ID=volc.seedasr.auc
ASR_VOLC_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
ASR_VOLC_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
ASR_VOLC_UPLOAD_PROVIDER=none
ASR_POLL_SECONDS=2
ASR_POLL_MAX_ATTEMPTS=120
PROVIDER_TIMEOUT_SECONDS=60
MAX_AUDIO_FILE_BYTES=26214400
RECORDING_STORAGE_DIR=./storage/recordings
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
MAX_PROCESSING_MINUTES=10
DEFAULT_SUBSCRIPTION_UNITS=6
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALLOW_INSECURE_HEADER_AUTH=false
SMS_PROVIDER=mock
SMS_HTTP_ENDPOINT=
SMS_HTTP_AUTH_TOKEN=
SMS_TEMPLATE=【BetweenUs】验证码 {code}，5 分钟内有效。
SMS_CODE_EXPIRES_SECONDS=300
SMS_SEND_INTERVAL_SECONDS=60
