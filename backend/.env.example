ENV=dev
DATABASE_URL=sqlite:///./betweenus.db
AI_PROVIDER_MODE=auto
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
ASR_API_KEY=
ASR_BASE_URL=https://api.openai.com/v1
