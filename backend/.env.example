DEFAULT_SUBSCRIPTION_UNITS=6
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALLOW_INSECURE_HEADER_AUTH=false
